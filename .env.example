# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=slotwise

# JWT Secret Configuration
JWT_SECRET=supersecretjwttokenchangeinproduction
