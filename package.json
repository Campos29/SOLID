{
  "name": "slotwise-api",
  "version": "1.0.0",
  "description": "Backend API for SlotWise using Fastify and Clean Architecture",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "migrate": "node scripts/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.mts"
  },
  "keywords": [
    "clean-architecture",
    "fastify",
    "postgresql",
    "solid",
    "gof"
  ],
  "author": "PUC-Campinas Software Engineering Students",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^9.0.1",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.13",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.6",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
